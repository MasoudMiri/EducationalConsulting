@using EducationalConsulting.DTOs
@model ArticleUpdateDto
@{
    ViewData["Title"] = "ویرایش مقاله";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as IEnumerable<CategoryDto>;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h4 class="mb-0">ویرایش مقاله</h4>
            </div>
            <div class="card-body">
                <form asp-action="EditArticle" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ExistingImageUrl" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">عنوان مقاله</label>
                        <input asp-for="Title" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Summary" class="form-label">خلاصه مقاله</label>
                        <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">دسته‌بندی</label>
                        <select asp-for="CategoryId" class="form-control" required>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label">عکس فعلی</label>
                            <div>
                                <img src="@Model.ExistingImageUrl" style="max-height: 150px; max-width: 200px;" class="border rounded p-2">
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="ImageFile" class="form-label">عکس جدید (اختیاری)</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*">
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label">محتوا</label>
                        <textarea asp-for="Content" id="editor" class="form-control" rows="15" required>@Model.Content</textarea>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox">
                        <label asp-for="IsActive" class="form-check-label">فعال باشد</label>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="@Url.Action("Articles")" class="btn btn-secondary">بازگشت</a>
                        <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        CKEDITOR.replace('editor', {
            language: 'fa',
            contentsLangDirection: 'rtl',
            height: 500,
            filebrowserUploadUrl: '/Upload/UploadFile',
            filebrowserImageUploadUrl: '/Upload/UploadFile'
        });
    </script>
}