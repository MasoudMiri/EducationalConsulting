@model IEnumerable<EducationalConsulting.DTOs.ArticleListDto>
@{
    Layout = "_Layout";
    ViewData["Title"] = $"مقالات {ViewBag.CategoryName}";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-5" style="color: #dbc64c;">مقالات @ViewBag.CategoryName</h1>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <h4>هیچ مقاله‌ای در این دسته یافت نشد.</h4>
            <p>به زودی مقالات جدید اضافه خواهند شد.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var article in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(article.ImageUrl))
                        {
                            <img src="@article.ImageUrl" class="card-img-top" alt="@article.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                                <span class="text-white">بدون عکس</span>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@article.Title</h5>
                            <p class="card-text text-muted">@(article.Summary?.Length > 100 ? article.Summary.Substring(0, 100) + "..." : article.Summary)</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">@article.CreateDate.ToString("yyyy/MM/dd")</small>
                                <small class="text-muted"><i class="fa fa-eye"></i> @article.ViewCount</small>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="@Url.Action("Details", "Articles", new { id = article.Id })" class="btn btn-warning w-100">مشاهده مقاله</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .card {
        transition: transform 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .btn-warning {
        background-color: #dbc64c;
        border: none;
        color: #000;
    }

        .btn-warning:hover {
            background-color: #c4b03b;
        }
</style>