@model EducationalConsulting.DTOs.PagedResult<EducationalConsulting.DTOs.ArticleListDto>
@{
    Layout = "_Layout";
    ViewData["Title"] = $"مقالات {ViewBag.CategoryName}";
}

<!-- فقط یک کادر (کادر پایینی) -->
<div class="category-header mb-4" style="background: #270b60; padding: 40px 20px; border-radius: 15px;">
    <h1 class="text-center" style="color: #dbc64c; font-weight: bold;">مقالات @ViewBag.CategoryName</h1>
    <p class="text-center" style="color: rgba(255,255,255,0.8);">مهم‌ترین مقالات آموزشی در دسته @ViewBag.CategoryName</p>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info text-center">
        <h4>هیچ مقاله‌ای در این دسته یافت نشد.</h4>
        <p>به زودی مقالات جدید اضافه خواهند شد.</p>
    </div>
}
else
{
    <div class="articles-list">
        @foreach (var article in Model.Items)
        {
            <div class="article-item mb-4 p-3 border-bottom">
                <div class="row">
                    @if (!string.IsNullOrEmpty(article.ImageUrl))
                    {
                        <div class="col-md-3">
                            <img src="@article.ImageUrl" alt="@article.Title" class="img-fluid rounded" style="height: 120px; width: 100%; object-fit: cover;">
                        </div>
                        <div class="col-md-9">
                            <h3><a href="@Url.Action("Details", "Articles", new { id = article.Id })" class="text-decoration-none" style="color: #270b60;">@article.Title</a></h3>
                            <p class="text-muted">@(article.Summary?.Length > 150 ? article.Summary.Substring(0, 150) + "..." : article.Summary)</p>
                            <div class="d-flex justify-content-between">
                                <small class="text-muted"><i class="fa fa-calendar"></i> @article.CreateDate.ToString("yyyy/MM/dd")</small>
                                <small class="text-muted"><i class="fa fa-eye"></i> @article.ViewCount بازدید</small>
                                <a href="@Url.Action("Details", "Articles", new { id = article.Id })" class="btn btn-sm" style="background-color: #dbc64c; border: none; color: #000; border-radius: 20px;">مشاهده مقاله</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="col-md-12">
                            <h3><a href="@Url.Action("Details", "Articles", new { id = article.Id })" class="text-decoration-none" style="color: #270b60;">@article.Title</a></h3>
                            <p class="text-muted">@(article.Summary?.Length > 200 ? article.Summary.Substring(0, 200) + "..." : article.Summary)</p>
                            <div class="d-flex justify-content-between">
                                <small class="text-muted"><i class="fa fa-calendar"></i> @article.CreateDate.ToString("yyyy/MM/dd")</small>
                                <small class="text-muted"><i class="fa fa-eye"></i> @article.ViewCount بازدید</small>
                                <a href="@Url.Action("Details", "Articles", new { id = article.Id })" class="btn btn-sm" style="background-color: #dbc64c; border: none; color: #000; border-radius: 20px;">مشاهده مقاله</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- صفحه‌بندی -->
    @if (Model.Pagination.TotalPages > 1)
    {
        <div class="pagination-container text-center mt-4">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    @if (Model.Pagination.HasPrevious)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("ListByCategory", new { categoryName = ViewBag.CategoryName, page = Model.Pagination.CurrentPage - 1 })">
                                <i class="fa fa-arrow-right"></i> قبلی
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                    {
                        if (i == Model.Pagination.CurrentPage)
                        {
                            <li class="page-item active"><span class="page-link" style="background-color: #270b60; border-color: #270b60; color: white;">@i</span></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="@Url.Action("ListByCategory", new { categoryName = ViewBag.CategoryName, page = i })">@i</a></li>
                        }
                    }

                    @if (Model.Pagination.HasNext)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("ListByCategory", new { categoryName = ViewBag.CategoryName, page = Model.Pagination.CurrentPage + 1 })">
                                بعدی <i class="fa fa-arrow-left"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
}

<style>
    .article-item {
        transition: all 0.3s ease;
    }

        .article-item:hover {
            background-color: #f8f9fa;
            transform: translateX(-5px);
        }

    .page-link {
        color: #270b60;
    }

    .page-item.active .page-link {
        background-color: #270b60 !important;
        border-color: #270b60 !important;
        color: white !important;
    }
</style>