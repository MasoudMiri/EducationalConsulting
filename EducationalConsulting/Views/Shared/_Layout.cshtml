<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="language" content="fa">

    <title>@ViewData["Title"] - گروه مشاورین SaLi</title>

    <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazir-font@v30.1.0/dist/font-face.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link rel="stylesheet" type="text/css" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <link rel="stylesheet" href="~/css/jquery.mCustomScrollbar.min.css">
    <link rel="stylesheet" href="~/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/css/owl.theme.default.min.css">
    <link rel="stylesheet" href="~/css/rtl-custom.css">

    <link rel="icon" href="~/images/fevicon.png" type="image/gif">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fancybox/2.1.5/jquery.fancybox.min.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <partial name="_Header" />

    <!-- عنوان صفحه (فقط برای صفحات غیر از صفحه اصلی و پنل ادمین) -->
    @{
        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
        var action = ViewContext.RouteData.Values["Action"]?.ToString();
        var isAdminPage = controller == "Admin";
        var isHomePage = controller == "Home" && action == "Index";
        var showPageTitle = !isAdminPage && !isHomePage;
    }

    @if (showPageTitle)
    {
        <div class="page-title-section" style="background: linear-gradient(135deg, #270b60 0%, #dbc64c 100%); padding: 60px 0; text-align: center; margin-bottom: 40px;">
            <div class="container">
                <h1 style="color: white; font-size: 48px; margin-bottom: 10px;">@ViewData["Title"]</h1>
                <p style="color: rgba(255,255,255,0.8); font-size: 18px;">
                    @if (controller == "Articles" && action == "ListByCategory")
                    {
                        @:لیست مقالات @ViewBag.CategoryName
                    }
                    else if (controller == "Articles" && action == "Details")
                    {
                        @:مشاهده مقاله
                    }
                </p>
            </div>
        </div>
    }

    <main role="main">
        <div class="container">
            @if (isAdminPage || isHomePage)
            {
                <!-- صفحه اصلی و پنل ادمین بدون سایدبار -->
                <div class="row">
                    <div class="col-12">
                        @RenderBody()
                    </div>
                </div>
            }
            else
            {
                <!-- سایر صفحات با سایدبار سمت چپ -->
                <div class="row">
                    <div class="col-md-4 col-lg-3">
                        @await Component.InvokeAsync("ImportantArticles", new { count = 5 })
                    </div>
                    <div class="col-md-8 col-lg-9">
                        @RenderBody()
                    </div>
                </div>
            }
        </div>
    </main>

    <partial name="_Footer" />

    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/popper.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/jquery-3.0.0.min.js"></script>
    <script src="~/js/plugin.js"></script>
    <script src="~/js/jquery.mCustomScrollbar.concat.min.js"></script>
    <script src="~/js/custom.js"></script>
    <script src="~/js/owl.carousel.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fancybox/2.1.5/jquery.fancybox.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>